<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="MinistryShift" Language="1034" Version="0.1.0" Manufacturer="MinistryShift Authors" UpgradeCode="a9f24b22-871d-4009-8b9a-7c90b6d12345">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Platform="x64" />

        <MajorUpgrade DowngradeErrorMessage="Una versión más nueva de [ProductName] ya está instalada." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="MinistryShift" Level="1" Display="expand" ConfigurableDirectory="INSTALLFOLDER">
            <Feature Id="CoreFiles" Title="Archivos del Programa" Description="Instala todos los archivos necesarios para ejecutar la aplicación." Level="1" AllowAdvertise="no" Absent="disallow">
                <ComponentGroupRef Id="AppComponents" />
            </Feature>
            <Feature Id="StartMenuShortcutFeature" Title="Acceso Directo en Menú Inicio" Description="Crea un acceso directo a la aplicación en el Menú de Inicio." Level="1" AllowAdvertise="no">
                <ComponentRef Id="ApplicationShortcut" />
            </Feature>
            <Feature Id="DesktopShortcutFeature" Title="Acceso Directo en el Escritorio" Description="Crea un acceso directo a la aplicación en tu Escritorio." Level="1" AllowAdvertise="no">
                <ComponentRef Id="ApplicationDesktopShortcut" />
            </Feature>
        </Feature>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="MinistryShift" />
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="MinistryShift"/>
            </Directory>
            <Directory Id="DesktopFolder" Name="Desktop" />
        </Directory>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="b9f24b22-871d-4009-8b9a-7c90b6d54321">
                <Shortcut Id="ApplicationStartMenuShortcut" 
                          Name="MinistryShift" 
                          Description="MinistryShift Desktop Application"
                          Target="[INSTALLFOLDER]ministry_shift.exe"
                          WorkingDirectory="INSTALLFOLDER"/>
                <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\MinistryShift" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>

        <DirectoryRef Id="DesktopFolder">
            <Component Id="ApplicationDesktopShortcut" Guid="c9f24b22-871d-4009-8b9a-7c90b6d98765">
                <Shortcut Id="ApplicationDesktopShortcutItem"
                          Name="MinistryShift"
                          Description="MinistryShift Desktop Application"
                          Target="[INSTALLFOLDER]ministry_shift.exe"
                          WorkingDirectory="INSTALLFOLDER"/>
                <RemoveFolder Id="CleanUpDesktopShortCut" Directory="DesktopFolder" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\MinistryShift" Name="desktop_shortcut" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>

        <UIRef Id="WixUI_FeatureTree" />
    </Product>
</Wix>
